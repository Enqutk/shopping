# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopping

# API (NestJS)
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
FRONTEND_URL=http://localhost:4200

# Google OAuth (required for this project)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
# Optional: Socket.IO origin if different from API host without /api
# NEXT_PUBLIC_REALTIME_URL=http://localhost:3000
