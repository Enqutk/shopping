# Copy to .env.prod on the VPS and fill in real values.
# Never commit .env.prod.

# --- Database (Docker network only) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=shopping

# --- API ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
FRONTEND_URL=http://35.159.83.79:4200
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud (domain recommended later)
GOOGLE_CALLBACK_URL=http://35.159.83.79:3001/api/auth/google/callback

# --- Frontend (baked into the image at build time) ---
NEXT_PUBLIC_API_URL=http://35.159.83.79:3001/api
# Keep false until Google OAuth redirect URIs work with your final domain
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
