# Copy to Dokploy Environment (or .env.prod on the VPS). Never commit real secrets.

# --- Database (Dokploy managed Postgres) ---
# App Name in Dokploy becomes the internal hostname (e.g. luxe-shopping).
DATABASE_URL=postgresql://postgres:change-me-to-a-long-random-password@luxe-shopping:5432/shopping

# --- API ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
FRONTEND_URL=https://luxeshopping.aklildr.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://luxeshopping.aklildr.com/api/auth/google/callback

# --- Frontend (baked into the image at build time) ---
NEXT_PUBLIC_API_URL=https://luxeshopping.aklildr.com/api
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
